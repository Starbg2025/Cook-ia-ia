# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# SUPABASE_URL: Your Supabase project URL
SUPABASE_URL="MY_SUPABASE_URL"
# SUPABASE_ANON_KEY: Your Supabase anonymous key
SUPABASE_ANON_KEY="MY_SUPABASE_ANON_KEY"

# Fallback AI Keys (Server-side)
NVIDIA_API_KEY="MY_NVIDIA_API_KEY"
GROQ_API_KEY="MY_GROQ_API_KEY"
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# Client-side / Netlify Fallback Keys (Optional, for static deploys)
VITE_NVIDIA_API_KEY="MY_NVIDIA_API_KEY"
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"
VITE_GROQ_API_KEY="MY_GROQ_API_KEY"
VITE_OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"
